#include <iostream>
#include <ctime>

using namespace std;

int diff = 1; // 1-easy, 2-normal, 3-hard
char op = '+'; // знак операции

void game() {
    setlocale(0, "");
    srand(time(NULL));

    int correct = 0;
    int wrong = 0;
    int lives = 3;
    int otvet;

    while (lives > 0) {
        int a, b, win;
        
        if (diff == 1) { a = rand() % 9 + 1; b = rand() % 9 + 1; }
        else if (diff == 2) { a = rand() % 90 + 10; b = rand() % 90 + 10; }
        else { a = rand() % 900 + 100; b = rand() % 900 + 100; }
        if (op == '+') win = a + b;
        else if (op == '-') win = a - b;
        else if (op == '*') win = a * b;
        else { if (b == 0) b = 1; a = a * b; win = a / b; } 

        cout << a << " " << op << " " << b << " = ";
        cin >> otvet;

        if (otvet == win) {
            cout << "Правильно!" << endl;
            correct++;
        } else {
            lives--;
            wrong++;
            cout << "Ошибка! Осталось жизней: " << lives << endl;
            cout << "Правильный ответ был: " << win << endl;
        }
        cout << "---" << endl;
    }

    cout << "\nПОРАЖЕНИЕ!" << endl;
    cout << "Итоговый счет: " << correct << " правильно, " << wrong << " ошибок." << endl;
}

int ext() {
    return 0;
}

void setting() {
    cout << "Выберите уровень (1-easy, 2-normal, 3-hard): ";
    cin >> diff;
    cout << "Выберите знак (+, -, *, /): ";
    cin >> op;
}

int main() {
    int wibop;
    setlocale(0, "");

    while (true) {
        cout << "1) play or die\n";
        cout << "2) settings\n";
        cout << "3) Exit\n";
        cin >> wibop;

        switch (wibop) {
        case 1: game(); break;
        case 2: setting(); break;
        case 3: return ext();
        }
    }
}
